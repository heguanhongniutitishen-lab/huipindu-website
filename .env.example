# Public site URL for SEO canonical/sitemap.
NEXT_PUBLIC_SITE_URL=https://huipindu-website.vercel.app

# Resend email notification configuration.
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Recipient email address for website consultation notifications.
CONTACT_NOTIFY_EMAIL=

# Sender email. Use onboarding@resend.dev for initial testing, or a verified domain sender in production.
CONTACT_FROM_EMAIL=慧拼读官网 <onboarding@resend.dev>

# Admin dashboard.
ADMIN_PASSWORD=

# Required in production if admin changes should write back to GitHub and trigger Vercel deployment.
GITHUB_TOKEN=
GITHUB_REPO=heguanhongniutitishen-lab/huipindu-website
GITHUB_BRANCH=main
